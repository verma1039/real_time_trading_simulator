# ── Application ──────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Database (PostgreSQL — Neon for production, local for dev) ──
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/trading_sim_dev

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
FRONTEND_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── JWT / Auth (Phase 2) ────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── Email — Gmail SMTP (Phase 2) ────────────────────────────
GMAIL_ADDRESS=your-project-email@gmail.com
GMAIL_APP_PASSWORD=replace-with-a-google-app-password

# ── Portfolio ────────────────────────────────────────────────
OPENING_BALANCE=1000000.0000
